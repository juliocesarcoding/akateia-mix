generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum ServerMode {
  MIX
  RETAKE
  DM
}

model Server {
  id           String     @id @default(cuid())
  name         String
  ip           String
  port         Int
  password    String
  mode         ServerMode @default(RETAKE)
  region       String?
  isActive     Boolean    @default(true)
  rconPassword String?    // depois a gente move pra secrets/cripto

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([ip, port])
}
model User {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Identidades
  steamId          String?  @unique
  email            String?  @unique
  passwordHash     String?

  // Perfil
  displayName      String?
  avatarUrl        String?
  nickname         String?  // ou "nome" do seu cadastro
  phone            String?
  profileCompleted Boolean  @default(false)

  // Controle
  isBanned         Boolean  @default(false)
}
